{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pgscope",
  "version": "0.1.0",
  "identifier": "dev.pgscope.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1425",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "pgscope",
        "width": 1400,
        "height": 880,
        "minWidth": 1180,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "theme": "Dark",
        "backgroundColor": "#0c0f15",
        "trafficLightPosition": { "x": 14, "y": 15 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "PostgreSQL explorer with a docked psql pane",
    "longDescription": "pgscope is a desktop PostgreSQL client: schema tree, paged data grid, column/index details, FK relationship graph, and an integrated psql-style terminal."
  }
}
